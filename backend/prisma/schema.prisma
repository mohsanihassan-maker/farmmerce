generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               Int            @id @default(autoincrement())
  email            String         @unique
  supabaseId       String?        @unique
  password         String
  name             String
  role             String         @default("BUYER")
  phone            String?
  address          String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  resetToken       String?
  resetTokenExpiry DateTime?
  groupMembers     GroupMember[]
  notifications    Notification[]
  orders           Order[]        @relation("BuyerOrders")
  deliveryTasks    Order[]        @relation("DeliveryOrders")
  products         Product[]
  profile          Profile?
  reviews          Review[]
  settlements      Settlement[]   @relation("FarmerSettlements")
}

model Profile {
  id            Int     @id @default(autoincrement())
  bio           String?
  location      String?
  phoneNumber   String?
  farmName      String?
  businessId    String?
  userId        Int     @unique
  bankName      String?
  accountNumber String?
  accountName   String?
  applicationStatus String? @default("NONE")
  user              User    @relation(fields: [userId], references: [id])
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Product {
  id             Int           @id @default(autoincrement())
  name           String
  description    String?
  price          Decimal
  unit           String
  stock          Int           @default(0)
  categoryName   String?
  imageUrl       String?
  traceabilityId String        @unique @default(uuid())
  harvestDate    DateTime?
  farmerId       Int
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  groupDeals     GroupDeal[]
  journey        JourneyStep[]
  orderItems     OrderItem[]
  category       Category?     @relation(fields: [categoryName], references: [name])
  farmer         User          @relation(fields: [farmerId], references: [id])
  reviews        Review[]
}

model JourneyStep {
  id          Int      @id @default(autoincrement())
  stage       String
  location    String
  date        DateTime @default(now())
  description String?
  productId   Int
  product     Product  @relation(fields: [productId], references: [id])
}

model Order {
  id              Int         @id @default(autoincrement())
  status          String      @default("PENDING")
  totalAmount     Decimal
  shippingAddress String?
  paymentMethod   String?
  deliveryDate    DateTime?
  trackingNote    String?
  buyerId         Int
  deliveryAgentId Int?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  buyer           User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  deliveryAgent   User?       @relation("DeliveryOrders", fields: [deliveryAgentId], references: [id])
  items           OrderItem[]
}

model OrderItem {
  id           Int         @id @default(autoincrement())
  orderId      Int
  productId    Int
  quantity     Int
  price        Decimal
  settlementId Int?
  order        Order       @relation(fields: [orderId], references: [id])
  product      Product     @relation(fields: [productId], references: [id])
  settlement   Settlement? @relation(fields: [settlementId], references: [id])
}

model Settlement {
  id             Int         @id @default(autoincrement())
  farmerId       Int
  amount         Decimal
  commission     Decimal
  netAmount      Decimal
  status         String      @default("PENDING")
  reference      String?     @unique
  settlementDate DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  items          OrderItem[]
  farmer         User        @relation("FarmerSettlements", fields: [farmerId], references: [id])
}

model Recipe {
  id           Int          @id @default(autoincrement())
  title        String
  description  String?
  instructions String?
  imageUrl     String?
  servings     Int          @default(4)
  mealType     String       @default("LUNCH")
  ingredients  Ingredient[]
}

model Ingredient {
  id             Int    @id @default(autoincrement())
  name           String
  productKeyword String
  quantity       Int
  recipeId       Int
  recipe         Recipe @relation(fields: [recipeId], references: [id])
}

model GroupDeal {
  id              Int         @id @default(autoincrement())
  title           String
  description     String?
  discountPrice   Decimal
  originalPrice   Decimal
  minParticipants Int         @default(4)
  durationHours   Int         @default(48)
  imageUrl        String?
  active          Boolean     @default(true)
  productId       Int
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  groups          DealGroup[]
  product         Product     @relation(fields: [productId], references: [id])
}

model DealGroup {
  id        Int           @id @default(autoincrement())
  status    String        @default("ACTIVE")
  expiresAt DateTime
  dealId    Int
  creatorId Int
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deal      GroupDeal     @relation(fields: [dealId], references: [id])
  members   GroupMember[]
}

model GroupMember {
  id       Int       @id @default(autoincrement())
  userId   Int
  groupId  Int
  joinedAt DateTime  @default(now())
  group    DealGroup @relation(fields: [groupId], references: [id])
  user     User      @relation(fields: [userId], references: [id])

  @@unique([userId, groupId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  body      String
  read      Boolean  @default(false)
  type      String   @default("INFO")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

model GlobalSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Bundle {
  id          Int      @id @default(autoincrement())
  name        String
  familySize  String
  price       Decimal
  savings     String?
  color       String?
  badge       String?
  imageUrl    String?
  accentColor String?
  featured    Boolean  @default(false)
  items       String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
